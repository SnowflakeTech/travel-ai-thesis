APP_NAME=Travel AI Thesis
APP_ENV=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/travel_ai_db
BACKEND_CORS_ORIGINS=http://localhost:3000

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

GEMINI_TEMPERATURE=0.4
GEMINI_MAX_OUTPUT_TOKENS=700
GEMINI_THINKING_BUDGET=0

CHAT_MAX_INPUT_CHARS=1200

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=travel_knowledge
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_VECTOR_SIZE=1024

RAG_TOP_K=5
RAG_MAX_CONTEXT_CHARS=4500
RAG_SCORE_THRESHOLD=0.35

MEMORY_MAX_ITEMS=20
MEMORY_EXTRACTION_MAX_OUTPUT_TOKENS=500
MEMORY_ENABLE_LLM_EXTRACTION=true